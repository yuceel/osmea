# Handle client-side routing for Flutter web with path-based URLs (no hash)
# This file ensures that all routes are handled by the Flutter app
# and prevents white screen issues on refresh

# Main app routes
/    /index.html   200
/home    /index.html   200
/demo    /index.html   200

# API and explorer routes
/api/*    /index.html   200
/explorer/*    /index.html   200
/settings/*    /index.html   200

# Handle static assets
/assets/*    /assets/*   200
/icons/*    /icons/*   200
/favicon.png    /favicon.png   200
/manifest.json    /manifest.json   200

# Catch all other routes and redirect to index.html
/*    /index.html   200
