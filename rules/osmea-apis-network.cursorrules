### 🌐 API Development Rules

#### 1. Service Structure
```dart
// ✅ Good Example - API Service
@injectable
class ShopifyStorefrontService {
  final ApiDioClient _dioClient;
  final ApiDioLogger _logger;

  ShopifyStorefrontService(this._dioClient, this._logger);

  Future<ApiResponse<Product>> getProduct(String productId) async {
    try {
      final response = await _dioClient.get('/products/$productId');
      return ApiResponse.success(Product.fromJson(response.data));
    } catch (e) {
      _logger.logError('Failed to get product: $e');
      return ApiResponse.error(ApiException.fromError(e));
    }
  }
}
```

#### 2. Response Handling
```dart
// ✅ Good Example - API Response
class ApiResponse<T> {
  final T? data;
  final ApiException? error;
  final bool isSuccess;

  ApiResponse.success(this.data) 
    : error = null, 
      isSuccess = true;

  ApiResponse.error(this.error) 
    : data = null, 
      isSuccess = false;

  factory ApiResponse.fromJson(Map<String, dynamic> json, T Function(Map<String, dynamic>) fromJson) {
    try {
      return ApiResponse.success(fromJson(json));
    } catch (e) {
      return ApiResponse.error(ApiException.fromError(e));
    }
  }
}
```

#### 3. Error Handling
```dart
// ✅ Good Example - API Exception
class ApiException implements Exception {
  final String message;
  final int? statusCode;
  final String? errorCode;
  final Map<String, dynamic>? details;

  ApiException({
    required this.message,
    this.statusCode,
    this.errorCode,
    this.details,
  });

  factory ApiException.fromError(dynamic error) {
    if (error is DioException) {
      return ApiException(
        message: error.message ?? 'Network error',
        statusCode: error.response?.statusCode,
        errorCode: error.response?.data?['error_code'],
        details: error.response?.data,
      );
    }
    return ApiException(message: error.toString());
  }
}
```

### 🔧 Dio Configuration Rules

#### 1. Client Setup
```dart
// ✅ Good Example - Dio Client
@injectable
class ApiDioClient {
  late final Dio _dio;

  ApiDioClient() {
    _dio = Dio(BaseOptions(
      baseUrl: 'https://api.example.com',
      connectTimeout: const Duration(seconds: 30),
      receiveTimeout: const Duration(seconds: 30),
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
      },
    ));

    _setupInterceptors();
  }

  void _setupInterceptors() {
    _dio.interceptors.addAll([
      ApiInterceptorDefault(),
      LogInterceptor(
        requestBody: true,
        responseBody: true,
        logPrint: (obj) => debugPrint(obj.toString()),
      ),
    ]);
  }

  Future<Response> get(String path, {Map<String, dynamic>? queryParameters}) {
    return _dio.get(path, queryParameters: queryParameters);
  }

  Future<Response> post(String path, {dynamic data}) {
    return _dio.post(path, data: data);
  }
}
```

#### 2. Interceptor Implementation
```dart
// ✅ Good Example - API Interceptor
class ApiInterceptorDefault extends Interceptor {
  @override
  void onRequest(RequestOptions options, RequestInterceptorHandler handler) {
    // Add authentication headers
    if (options.headers['Authorization'] == null) {
      options.headers['Authorization'] = 'Bearer ${getAccessToken()}';
    }
    
    // Add request ID for tracking
    options.headers['X-Request-ID'] = generateRequestId();
    
    handler.next(options);
  }

  @override
  void onResponse(Response response, ResponseInterceptorHandler handler) {
    // Handle successful responses
    handler.next(response);
  }

  @override
  void onError(DioException err, ErrorInterceptorHandler handler) {
    // Handle errors and retry logic
    if (err.response?.statusCode == 401) {
      // Handle authentication error
      refreshToken().then((_) {
        // Retry original request
        handler.resolve(err.response!);
      });
    } else {
      handler.next(err);
    }
  }
}
```

### 🛒 Shopify Integration Rules

#### 1. Storefront API
```dart
// ✅ Good Example - Shopify Storefront Service
@injectable
class ShopifyStorefrontService {
  final ApiDioClient _dioClient;
  final String _storefrontAccessToken;

  ShopifyStorefrontService(this._dioClient, @factoryParam this._storefrontAccessToken);

  Future<ApiResponse<List<Product>>> getProducts({
    int? first,
    String? after,
    String? query,
  }) async {
    try {
      final response = await _dioClient.post('/graphql', data: {
        'query': '''
          query getProducts(\$first: Int, \$after: String, \$query: String) {
            products(first: \$first, after: \$after, query: \$query) {
              edges {
                node {
                  id
                  title
                  handle
                  description
                  priceRange {
                    minVariantPrice {
                      amount
                      currencyCode
                    }
                  }
                  images(first: 1) {
                    edges {
                      node {
                        url
                        altText
                      }
                    }
                  }
                }
              }
              pageInfo {
                hasNextPage
                endCursor
              }
            }
          }
        ''',
        'variables': {
          'first': first,
          'after': after,
          'query': query,
        },
      });

      return ApiResponse.success(
        _parseProductsResponse(response.data),
      );
    } catch (e) {
      return ApiResponse.error(ApiException.fromError(e));
    }
  }
}
```

#### 2. Admin API
```dart
// ✅ Good Example - Shopify Admin Service
@injectable
class ShopifyAdminService {
  final ApiDioClient _dioClient;
  final String _adminAccessToken;

  ShopifyAdminService(this._dioClient, @factoryParam this._adminAccessToken);

  Future<ApiResponse<Order>> createOrder(CreateOrderRequest request) async {
    try {
      final response = await _dioClient.post('/admin/api/2023-10/orders.json', data: {
        'order': request.toJson(),
      });

      return ApiResponse.success(Order.fromJson(response.data['order']));
    } catch (e) {
      return ApiResponse.error(ApiException.fromError(e));
    }
  }
}
```

### 🌐 WooCommerce Integration Rules

#### 1. REST API Service
```dart
// ✅ Good Example - WooCommerce Service
@injectable
class WooCommerceService {
  final ApiDioClient _dioClient;
  final String _consumerKey;
  final String _consumerSecret;

  WooCommerceService(
    this._dioClient,
    @factoryParam this._consumerKey,
    @factoryParam this._consumerSecret,
  );

  Future<ApiResponse<List<Product>>> getProducts({
    int? page,
    int? perPage,
    String? category,
  }) async {
    try {
      final response = await _dioClient.get('/wp-json/wc/v3/products', 
        queryParameters: {
          'page': page,
          'per_page': perPage,
          'category': category,
        },
      );

      return ApiResponse.success(
        (response.data as List).map((json) => Product.fromJson(json)).toList(),
      );
    } catch (e) {
      return ApiResponse.error(ApiException.fromError(e));
    }
  }
}
```

### 🔄 Retry Logic Rules

#### 1. Retry Implementation
```dart
// ✅ Good Example - Retry Logic
class RetryInterceptor extends Interceptor {
  final int maxRetries;
  final Duration retryDelay;

  RetryInterceptor({
    this.maxRetries = 3,
    this.retryDelay = const Duration(seconds: 1),
  });

  @override
  void onError(DioException err, ErrorInterceptorHandler handler) async {
    if (_shouldRetry(err) && _getRetryCount(err.requestOptions) < maxRetries) {
      await Future.delayed(retryDelay);
      
      try {
        final response = await _retryRequest(err.requestOptions);
        handler.resolve(response);
        return;
      } catch (e) {
        // Continue with error handling
      }
    }
    
    handler.next(err);
  }

  bool _shouldRetry(DioException error) {
    return error.type == DioExceptionType.connectionTimeout ||
           error.type == DioExceptionType.receiveTimeout ||
           error.response?.statusCode == 500 ||
           error.response?.statusCode == 502 ||
           error.response?.statusCode == 503;
  }
}
```

### 📝 Logging Rules

#### 1. API Logger
```dart
// ✅ Good Example - API Logger
@injectable
class ApiDioLogger implements ApiDioLoggerAbstract {
  @override
  void logRequest(RequestOptions options) {
    debugPrint('🌐 API Request: ${options.method} ${options.path}');
    debugPrint('Headers: ${options.headers}');
    debugPrint('Data: ${options.data}');
  }

  @override
  void logResponse(Response response) {
    debugPrint('✅ API Response: ${response.statusCode} ${response.requestOptions.path}');
    debugPrint('Data: ${response.data}');
  }

  @override
  void logError(dynamic error) {
    debugPrint('❌ API Error: $error');
  }
}
```

### 🔐 Authentication Rules

#### 1. Token Management
```dart
// ✅ Good Example - Token Manager
@injectable
class TokenManager {
  final SharedPreferences _prefs;
  
  TokenManager(this._prefs);

  Future<void> saveAccessToken(String token) async {
    await _prefs.setString('access_token', token);
  }

  String? getAccessToken() {
    return _prefs.getString('access_token');
  }

  Future<void> clearTokens() async {
    await _prefs.remove('access_token');
    await _prefs.remove('refresh_token');
  }

  Future<bool> refreshToken() async {
    try {
      // Implement token refresh logic
      return true;
    } catch (e) {
      return false;
    }
  }
}
```

### 🔍 Code Quality Standards

#### 1. Documentation
- Document all API endpoints
- Include request/response examples
- Document error codes and messages
- Add inline comments for complex logic

#### 2. Testing
- Write unit tests for all services
- Mock network responses
- Test error scenarios
- Test retry logic

#### 3. Performance
- Implement request caching
- Use connection pooling
- Optimize payload sizes
- Monitor response times

### 🚀 Best Practices

1. **Error Handling**: Implement comprehensive error handling
2. **Retry Logic**: Add retry mechanisms for transient failures
3. **Caching**: Implement appropriate caching strategies
4. **Security**: Use secure authentication methods
5. **Monitoring**: Log and monitor API performance
6. **Documentation**: Maintain up-to-date API documentation

### 🔍 Code Review Checklist

- [ ] API services follow established patterns
- [ ] Error handling is comprehensive
- [ ] Retry logic is implemented
- [ ] Authentication is secure
- [ ] Logging is appropriate
- [ ] Caching is implemented
- [ ] Tests are comprehensive
- [ ] Documentation is complete
- [ ] Performance is optimized
- [ ] Security measures are in place

